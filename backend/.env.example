# Backend environment variables
# Copy to .env and fill in values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:***@cluster0.z3cgb58.mongodb.net/?appName=Cluster0

# JWT secret — use a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_me

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Server port
PORT=6767

# Upstash Redis (optional — enables cross-instance semantic cache)
# Free tier: https://console.upstash.com → Create Redis Database → REST API
REDIS_URL=https://xxx.upstash.io
REDIS_TOKEN=***

# Sentry (optional — production error tracking)
# Create a project at https://sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=https://xxx@sentry.io/xxx
